# Copier ce fichier en `.env` puis renseigner les valeurs.
# Générer une SECRET_KEY :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=changeme-generate-a-real-key
DEBUG=True

# Compte de démonstration communiqué dans le dossier technique.
# Créé automatiquement au démarrage si ces deux variables sont définies
# (voir users/management/commands/ensure_demo_account.py).
# À renseigner sur l'hébergeur uniquement : ne jamais committer de vraie valeur.
# DEMO_ACCOUNT_EMAIL=jury@exemple.fr
# DEMO_ACCOUNT_PASSWORD=change-me

# OpenRouteService (https://openrouteservice.org) — clé gratuite, 2000 req/jour.
ORS_API_KEY=your-ors-api-key

# JCDecaux (https://developer.jcdecaux.com) — vélos en libre-service.
# Ne couvre PAS Paris (Vélib' est exploité par Smovengo) : sert les autres villes.
JCDECAUX_API_KEY=your-jcdecaux-api-key

# Île-de-France Mobilités / PRIM (https://prim.iledefrance-mobilites.fr)
# — perturbations du réseau de transport.
VELIB_PRIM_API_KEY=your-prim-api-key

# Note : la disponibilité Vélib' provient de l'Open Data de Paris
# (opendata.paris.fr) et ne nécessite aucune clé.

# Base de données. En production, DATABASE_URL est la variable à privilégier :
# c'est celle qu'injecte le service PostgreSQL de Railway.
# Sans elle (ni les PG* ci-dessous), Django retombe sur SQLite — acceptable en
# local, mais destructeur en production où le disque est éphémère.
# DATABASE_URL=postgres://utilisateur:motdepasse@hote:5432/base

# PostgreSQL — laisser vide en local pour basculer automatiquement sur SQLite.
# PGDATABASE=urbanflow
# PGUSER=urbanflow
# PGPASSWORD=changeme
# PGHOST=127.0.0.1
# PGPORT=5432
